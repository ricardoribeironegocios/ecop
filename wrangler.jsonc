{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ricardoribeiro",
  "main": "workers/index.js",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./out",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
